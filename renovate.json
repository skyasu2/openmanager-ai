{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies", "automated"],
  "assignees": ["skyasu2"],
  "reviewers": ["skyasu2"],
  "rangeStrategy": "bump",
  "timezone": "Asia/Seoul",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "platformAutomerge": false,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "typescript-core",
      "matchPackageNames": ["typescript"]
    },
    {
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "types",
      "matchPackageNames": ["/^@types\\//"]
    },
    {
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "testing",
      "matchPackageNames": [
        "/^vitest$/",
        "/^@vitest\\//",
        "/^@testing-library\\//"
      ]
    },
    {
      "description": "Keep Playwright packages aligned.",
      "matchDepTypes": ["devDependencies"],
      "groupName": "playwright",
      "matchPackageNames": ["/^playwright$/", "/^@playwright\\//"]
    },
    {
      "description": "Keep Storybook packages aligned.",
      "matchDepTypes": ["devDependencies"],
      "groupName": "storybook",
      "matchPackageNames": ["/^storybook$/", "/^@storybook\\//"]
    },
    {
      "matchDepTypes": ["dependencies", "devDependencies"],
      "groupName": "linting",
      "matchPackageNames": ["/^@biomejs\\//", "/^eslint/", "/^prettier/"]
    },
    {
      "matchDepTypes": ["dependencies"],
      "groupName": "react",
      "matchPackageNames": ["react", "react-dom"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "groupName": "react-types",
      "matchPackageNames": ["/^@types\\/react/"]
    },
    {
      "matchDepTypes": ["dependencies"],
      "groupName": "ai-sdk",
      "matchPackageNames": ["/^ai$/", "/^@ai-sdk\\//"]
    },
    {
      "description": "Keep Hono runtime packages aligned.",
      "matchDepTypes": ["dependencies"],
      "groupName": "hono-runtime",
      "matchPackageNames": ["/^hono$/", "/^@hono\\/node-server$/"]
    },
    {
      "description": "Group AI Engine runtime infrastructure updates.",
      "matchFileNames": ["cloud-run/ai-engine/package.json"],
      "matchDepTypes": ["dependencies"],
      "groupName": "ai-engine-runtime",
      "matchPackageNames": [
        "/^@google-cloud\\/pino-logging-gcp-config$/",
        "/^@opentelemetry\\/api$/",
        "/^@supabase\\/supabase-js$/",
        "/^@tavily\\/core$/",
        "/^@upstash\\/redis$/",
        "/^dotenv$/",
        "/^js-tiktoken$/",
        "/^langfuse$/",
        "/^pg$/",
        "/^pino$/",
        "/^promptfoo$/",
        "/^zod$/"
      ]
    },
    {
      "matchUpdateTypes": ["patch"],
      "labels": ["dependencies", "automated", "patch-update"]
    },
    {
      "matchUpdateTypes": ["minor", "major"],
      "labels": ["dependencies", "automated", "needs-review"]
    }
  ]
}
