# ========================================
# AI Engine Environment Variables (Local Development)
# ========================================

# ========================================
# LangFuse Configuration (Observability)
# ========================================
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
LANGFUSE_SAMPLE_RATE="0.1"         # 샘플링 비율 (0.0~1.0, 기본 0.1=10%)
LANGFUSE_TEST_MODE="false"         # true 시 즉시 플러시, 100% 추적

# ========================================
# Supabase Configuration (Vector Search / Embeddings)
# ========================================
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ========================================
# Google AI Configuration (Embeddings)
# ========================================
GOOGLE_AI_API_KEY=""
GOOGLE_AI_API_KEY_SECONDARY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"

# ========================================
# AI Providers Configuration
# ========================================
GROQ_API_KEY=""
GROQ_MODEL_ID="meta-llama/llama-4-scout-17b-16e-instruct"  # 500K TPD, 131K ctx (2026-04-25)
MISTRAL_API_KEY=""
MISTRAL_MODEL_ID="mistral-small-latest"                     # Free-tier friendly last-resort fallback; account model list smoke passed 2026-05-02
CEREBRAS_API_KEY=""
CEREBRAS_MODEL_ID="gpt-oss-120b"                            # Production Cerebras runtime (switched 2026-05-21); llama3.1-8b deprecated 2026-05-27
CEREBRAS_FALLBACK_MODEL_IDS=""                              # Keep empty; gpt-oss-120b is primary, no intra-Cerebras fallback needed
CEREBRAS_TOOL_CALLING_ENABLED="true"                        # true: tool-calling 에이���트 fallback 활성화
CEREBRAS_LONG_CONTEXT_ENABLED="true"                        # context window for gpt-oss-120b unconfirmed; 32K+ reqs skip Cerebras by capability
GEMINI_API_KEY=""
GEMINI_VISION_MODEL_ID="gemini-2.5-flash-lite"              # thinking=0, RPD 1,000 (flash은 thinking 소비)
TAVILY_API_KEY=""
# Explicit single / degraded fallback gate (auto mode still follows query complexity)
ALLOW_DEGRADED_SINGLE="false"

# ========================================
# API Authentication
# ========================================
CLOUD_RUN_API_SECRET="your-secure-api-secret-here"

# Cloud Tasks dispatch for async Job Queue processing (optional)
CLOUD_TASKS_ENABLED=false
CLOUD_TASKS_PROJECT_ID="your-gcp-project-id"
CLOUD_TASKS_LOCATION="asia-northeast1"
CLOUD_TASKS_QUEUE_ID="openmanager-ai-jobs"
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=""
CLOUD_TASKS_OIDC_AUDIENCE=""
CLOUD_TASKS_DISPATCH_DEADLINE_SECONDS=600

# ========================================
# Upstash Redis (KV) Configuration
# ========================================
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
