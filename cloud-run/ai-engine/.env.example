# ========================================
# AI Engine Environment Variables (Local Development)
# ========================================

# ========================================
# LangFuse Configuration (Observability)
# ========================================
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
LANGFUSE_SAMPLE_RATE="0.1"         # 샘플링 비율 (0.0~1.0, 기본 0.1=10%)
LANGFUSE_TEST_MODE="false"         # true 시 즉시 플러시, 100% 추적

# ========================================
# Supabase Configuration (Vector Search / Embeddings)
# ========================================
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ========================================
# Google AI Configuration (Embeddings)
# ========================================
GOOGLE_AI_API_KEY=""
GOOGLE_AI_API_KEY_SECONDARY=""
GOOGLE_AI_MODEL="gemini-2.5-flash"

# ========================================
# AI Providers Configuration
# ========================================
GROQ_API_KEY=""
GROQ_MODEL_ID="meta-llama/llama-4-scout-17b-16e-instruct"  # 500K TPD, 512K ctx (2026-04-04)
MISTRAL_API_KEY=""
CEREBRAS_API_KEY=""
CEREBRAS_MODEL_ID="qwen-3-235b-a22b-instruct-2507"          # Preview 상태, structured routing primary
CEREBRAS_TOOL_CALLING_ENABLED="false"                       # 기본 false: Cerebras는 structured-output 위주, tool loop는 opt-in
GEMINI_API_KEY=""
GEMINI_VISION_MODEL_ID="gemini-2.5-flash-lite"              # thinking=0, RPD 1,000 (flash은 thinking 소비)
TAVILY_API_KEY=""
# Explicit single / degraded fallback gate (auto mode still follows query complexity)
ALLOW_DEGRADED_SINGLE="false"

# ========================================
# OpenRouter Configuration (Vision Agent Fallback)
# ========================================
OPENROUTER_API_KEY=""
OPENROUTER_DEFAULT_MODEL="meta-llama/llama-3.1-8b-instruct:free"
# 2026-04-04 실테스트 기준: nemotron(content=None), mistral-small-3.1:free(404) 제거
OPENROUTER_MODEL_VISION="google/gemma-3-27b-it:free"
OPENROUTER_MODEL_VISION_FALLBACKS="google/gemma-3-12b-it:free,google/gemma-3-4b-it:free"
# OpenRouter app attribution headers (recommended)
OPENROUTER_HTTP_REFERER=""
OPENROUTER_X_TITLE="OpenManager AI"
# Free-tier vision models often fail on tool calling; default=false
OPENROUTER_VISION_TOOL_CALLING="false"

# ========================================
# API Authentication
# ========================================
CLOUD_RUN_API_SECRET="your-secure-api-secret-here"

# ========================================
# Upstash Redis (KV) Configuration
# ========================================
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
