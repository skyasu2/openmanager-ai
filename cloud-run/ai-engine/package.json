{
  "name": "ai-engine",
  "version": "8.11.119",
  "description": "Vercel AI SDK Supervisor Engine for Cloud Run",
  "license": "GPL-3.0-only",
  "author": "skyasu2 (https://github.com/skyasu2)",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyasu2/openmanager-ai.git",
    "directory": "cloud-run/ai-engine"
  },
  "packageManager": "npm@11.10.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "verify:rag": "node -e \"import('ai').then(() => console.log('verify:rag ok')).catch((err) => { console.error('verify:rag failed:', err?.message || err); process.exit(1); })\"",
    "type-check": "tsc --noEmit",
    "line-guard": "node ../../scripts/dev/line-count-guard.js --warn 500 --fail 800 --include src --root .",
    "test": "SKIP_VISION_TESTS=1 LOG_LEVEL=error vitest run --silent=passed-only",
    "test:core": "SKIP_VISION_TESTS=1 LOG_LEVEL=error vitest run --silent=passed-only",
    "test:all": "LOG_LEVEL=error vitest run --silent=passed-only",
    "test:vision": "LOG_LEVEL=error vitest run --silent=passed-only src/services/ai-sdk/agents/vision-agent.test.ts src/services/ai-sdk/agents/config/agent-configs.vision-fallback.test.ts",
    "test:watch": "vitest",
    "docker:preflight": "bash scripts/docker-preflight.sh",
    "backtest": "tsx scripts/backtest-trend-projection.ts",
    "backtest:json": "tsx scripts/backtest-trend-projection.ts --json",
    "rag:analyze": "tsx scripts/analyze-rag-distribution.ts",
    "rag:merge:plan": "tsx scripts/rag-merge-plan.ts",
    "rag:merge:apply": "tsx scripts/rag-merge-apply.ts",
    "prompt:eval": "node scripts/promptfoo/preflight.mjs promptfoo/promptfooconfig.yaml && promptfoo eval -c promptfoo/promptfooconfig.yaml",
    "prompt:view": "promptfoo view",
    "prompt:redteam": "node scripts/promptfoo/preflight.mjs promptfoo/redteam/security-tests.yaml && promptfoo eval -c promptfoo/redteam/security-tests.yaml",
    "prompt:cache:clear": "promptfoo cache clear"
  },
  "dependencies": {
    "@ai-sdk/cerebras": "^2.0.50",
    "@ai-sdk/google": "^3.0.68",
    "@ai-sdk/groq": "^3.0.38",
    "@ai-sdk/mistral": "^3.0.35",
    "@ai-sdk/openai": "^3.0.62",
    "@google-cloud/pino-logging-gcp-config": "^1.3.5",
    "@hono/node-server": "^1.19.14",
    "@opentelemetry/api": "^1.9.1",
    "@supabase/supabase-js": "^2.105.3",
    "@tavily/core": "^0.6.0",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.175",
    "dotenv": "^16.4.7",
    "hono": "^4.12.18",
    "js-tiktoken": "^1.0.21",
    "langfuse": "^3.38.20",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "promptfoo": "^0.120.8",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0 <12.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.0.0 <25.0.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "error"
    }
  }
}
