# Cloud Run Local Development Environment
# Copy this file to .env and fill in your API keys
# This file is for local Docker Compose compatibility only.
# Production Cloud Run uses grouped GCP Secret Manager values via deploy.sh.

# ========================================
# Gemini API Keys (AI Engine runtime)
# Runtime parser priority: GEMINI_API_KEY -> GEMINI_API_KEY_PRIMARY.
# If you still have a legacy GOOGLE_API_KEY value, copy it to GEMINI_API_KEY_PRIMARY.
# ========================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_KEY_PRIMARY=your-gemini-api-key-here
GEMINI_API_KEY_SECONDARY=your-secondary-gemini-key-here

# ========================================
# Google AI Rate Limits (Gemini 2.5 Flash Free Tier)
# ========================================
GOOGLE_AI_RPM_LIMIT=10
GOOGLE_AI_RPD_LIMIT=250

# ========================================
# Cerebras / Groq / Mistral API Keys
# ========================================
CEREBRAS_API_KEY=your-cerebras-api-key-here
GROQ_API_KEY=your-groq-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here

# ========================================
# Supabase Configuration
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct connection for LangGraph Checkpointer (non-pooling)
SUPABASE_DIRECT_URL=postgres://postgres:password@host:5432/postgres

# ========================================
# Database Pool Configuration
# ========================================
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY_MS=1000

# ========================================
# Cloud Run API Secret (for local testing)
# Maps to secret: cloud-run-api-secret
# ========================================
CLOUD_RUN_API_SECRET=test-secret

# ========================================
# Upstash Redis (Optional - for caching)
# ========================================
# KV_REST_API_URL=https://your-redis.upstash.io
# KV_REST_API_TOKEN=your-upstash-token

# ========================================
# Optional integrations
# ========================================
# TAVILY_API_KEY=your-tavily-api-key-here
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
