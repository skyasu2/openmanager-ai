{
  "$schema": "./intent-patterns.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2026-06-14",
  "ruleVersion": "bff",
  "patterns": {
    "artifact_negation": {
      "source": "(말고|아니고|없이|나중에|필요\\s*없|하지\\s*마|하지\\s*말|제외)",
      "flags": "i",
      "description": "Artifact 실행을 명시적으로 부정하거나 제외하는 표현",
      "examples": ["아티팩트 하지 마", "보고서는 나중에"],
      "counterExamples": ["아티팩트 만들어줘"]
    },
    "artifact_formatting_only": {
      "source": "(보고서용|리포트용|문장으로|문장만|다시\\s*작성|재작성|고쳐\\s*써|다듬어|rewrite|rephrase|paraphrase)",
      "flags": "i",
      "description": "새 artifact 실행이 아니라 기존 답변/문장을 다듬는 요청",
      "examples": ["보고서용 문장으로 다시 작성", "rewrite this"],
      "counterExamples": ["장애 보고서 작성해줘"]
    },
    "artifact_explicit_execution": {
      "source": "(아티팩트|artifact|생성|만들|다운로드|내려받|실행|돌려|뽑아|출력|export|generate|download|create|run)",
      "flags": "i",
      "description": "Artifact를 실제로 생성하거나 실행하라는 명시적 동사",
      "examples": ["아티팩트 생성", "report export"],
      "counterExamples": ["기능 설명"]
    },
    "artifact_how_to_request": {
      "source": "(설명|안내|어떻게|방법|사용법|어디\\s*(?:서|에서)?|가능|되나|뭐야|무엇|무슨|지원|위치|어떤)",
      "flags": "i",
      "description": "Artifact 실행이 아니라 기능 설명, 위치, 사용 방법을 묻는 표현",
      "examples": ["장애 보고서 작성 방법 알려줘", "추세 기능 어디서 봐?"],
      "counterExamples": ["장애 보고서 기능 실행해줘"]
    },
    "incident_report": {
      "source": "(장애\\s*(보고서|리포트|보고)|인시던트\\s*(보고서|리포트)|incident\\s*report)",
      "flags": "i",
      "description": "Incident report artifact shape",
      "examples": ["장애 보고서", "incident report"],
      "counterExamples": ["이상감지"]
    },
    "incident_report_action": {
      "source": "(작성(?!\\s*(방법|법|기능|설명|안내))|생성(?!\\s*(방법|법|기능|설명|안내))|만들|만들어|다운로드(?!\\s*(방법|법|기능|설명|안내))|내려받|부탁|요청|실행|돌려|뽑아|출력|export|generate|download|run)",
      "flags": "i",
      "description": "Incident report를 실행 요청으로 승격하는 action 표현",
      "examples": ["작성해줘", "download"],
      "counterExamples": ["작성 방법", "다운로드 방법"]
    },
    "monitoring": {
      "source": "(이상\\s*감지|이상감지|이상\\s*탐지|추세|트렌드|리스크\\s*(추세|분석)|예측|예상|anomaly|forecast|trend)",
      "flags": "i",
      "description": "Monitoring analysis 후보가 되는 도메인 키워드",
      "examples": ["이상감지", "trend"],
      "counterExamples": ["장애 보고서"]
    },
    "capacity_forecast_exclusion": {
      "source": "(?:언제.{0,24}\\d+\\s*%?.{0,24}(?:넘|초과|도달|돌파)|\\d+\\s*%?.{0,24}(?:넘|초과|도달|돌파).{0,24}(?:언제|시점|예측)|(?:넘|초과|도달|돌파).{0,16}(?:시점|예측)|(?:위험\\s*(?:수준|레벨|임계|단계)|critical\\s*(?:level|threshold)).{0,24}(?:도달|초과|넘|시점|예측|reach|hit)|용량\\s*(?:예측|계획|부족|고갈)|capacity\\s*(?:forecast|plan|planning|projection)|임계(?:치|값)?.{0,24}(?:도달|초과|넘|시점)|(?:고갈|포화|가득\\s*차|가득\\s*찰).{0,16}(?:예측|시점|언제|예상|알려)|디스크\\s*(?:가득|고갈|부족)\\s*(?:언제|예상))",
      "flags": "i",
      "description": "용량 예측/임계치 도달 시점 질의는 artifact 대신 일반 AI 경로로 보낸다",
      "examples": ["언제 90% 넘을까", "capacity forecast"],
      "counterExamples": ["전체 서버 이상감지 돌려줘"]
    },
    "monitoring_action": {
      "source": "(분석\\s*(해|해줘|해주세요|해줄래|좀|부탁|요청)|분석해|실행|돌려|요약\\s*(해|해줘|해주세요|해줄래|부탁|요청)|요약해|확인\\s*(해|해줘|해주세요|해줄래|부탁|요청)|확인해|생성(?!\\s*(방법|법|기능|설명|안내))|만들|다운로드(?!\\s*(방법|법|기능|설명|안내))|예측\\s*(해|해줘|해주세요|해줄래|부탁|요청)|예측해|forecast|analy[sz]e|run)",
      "flags": "i",
      "description": "Monitoring analysis를 실행 요청으로 승격하는 action 표현",
      "examples": ["분석해줘", "analyze"],
      "counterExamples": ["분석 방법"]
    },
    "monitoring_artifact": {
      "source": "(이상\\s*감지|이상감지|이상\\s*탐지|추세\\s*(분석|리포트|보고서)|트렌드\\s*(분석|리포트|보고서)|리스크\\s*(추세|분석)|장애\\s*(예측|예상)|예측\\s*(분석|리포트|보고서)|anomaly\\s*detection|forecast|trend\\s*(analysis|report)?)",
      "flags": "i",
      "description": "짧은 implicit monitoring artifact shape",
      "examples": ["추세 분석", "anomaly detection"],
      "counterExamples": ["CPU 높은 서버"]
    },
    "whole_system_monitoring": {
      "source": "(전체\\s*(서버|시스템|인프라|스캔)|모든\\s*(서버|시스템|인프라)|전\\s*서버|캐스케이드|cascade|all\\s*servers?|full\\s*(scan|system))",
      "flags": "i",
      "description": "전체/모든/cascade 표현은 단일 서버 artifact 승격을 막는다",
      "examples": ["전체 서버 분석", "cascade 영향도"],
      "counterExamples": ["api-was-dc1-01 분석"]
    },
    "ops_procedure_operational_context": {
      "source": "(서버|인프라|운영|모니터링|장애|로그|에러|경고|cpu|메모리|memory|디스크|disk|네트워크|network|promql|prometheus|alertmanager|slack|슬랙|webhook|runbook|런북)",
      "flags": "i",
      "description": "Ops procedure artifact가 OpenManager 운영 도메인 안에 있는지 판단하는 context 표현",
      "examples": ["CPU 알림", "prometheus"],
      "counterExamples": ["피보나치"]
    },
    "ops_procedure_shape": {
      "source": "(스크립트|script|bash|shell|쉘|slack|슬랙|webhook|alertmanager|prometheus|promql|알림\\s*(규칙|설정|스크립트)?|runbook|런북|대응\\s*(순서|절차)|원인과\\s*대응|확인\\s*명령어)",
      "flags": "i",
      "description": "Ops procedure 산출물 형태",
      "examples": ["bash 스크립트", "runbook"],
      "counterExamples": ["분석해줘"]
    },
    "ops_procedure_action": {
      "source": "(짜줘|작성|생성|만들|만들어|알려줘|정리|출력|generate|create|write|build|draft)",
      "flags": "i",
      "description": "Ops procedure 생성을 요청하는 action 표현",
      "examples": ["짜줘", "write"],
      "counterExamples": ["읽어줘"]
    },
    "ops_procedure_followup_edit": {
      "source": "(이\\s*)?(스크립트|설정|룰|rule|runbook|런북|절차).{0,80}(임계치|임계값|threshold).{0,80}(바꿔|변경|수정|올려|낮춰|change|update)",
      "flags": "i",
      "description": "이전 ops procedure 산출물의 임계치/threshold 수정 follow-up",
      "examples": ["이 스크립트에서 임계치를 90%로 바꿔줘"],
      "counterExamples": ["스크립트 알려줘"]
    },
    "llm_artifact_candidate": {
      "source": "(장애|인시던트|incident|보고서|리포트|report|이상\\s*(감지|탐지)|이상감지|추세|트렌드|리스크|예측|모니터링|anomaly|forecast|trend|risk)",
      "flags": "i",
      "description": "Optional LLM artifact intent route를 호출할 수 있는 후보 키워드",
      "examples": ["보고서", "forecast"],
      "counterExamples": ["날씨"]
    },
    "llm_artifact_action_hint": {
      "source": "(작성|생성|만들|부탁|요청|뽑아|출력|다운로드|내려받|실행|돌려|요약|확인|해줘|해주세요|해줄래|분석\\s*(해|해줘|해주세요|좀|부탁|요청)|export|generate|download|create|write|analy[sz]e|run)",
      "flags": "i",
      "description": "Optional LLM artifact intent route 후보를 강화하는 action hint",
      "examples": ["작성", "generate"],
      "counterExamples": ["방법"]
    },
    "llm_artifact_shape": {
      "source": "(보고서|리포트|report|이상\\s*감지|이상감지|이상\\s*탐지|추세\\s*(분석|리포트|보고서)|트렌드\\s*(분석|리포트|보고서)|리스크\\s*(추세|분석)|장애\\s*(예측|예상)|예측\\s*(분석|리포트|보고서)|anomaly\\s*detection|forecast|trend\\s*(analysis|report)|risk\\s*analysis)",
      "flags": "i",
      "description": "Optional LLM artifact intent route 후보를 강화하는 artifact shape",
      "examples": ["risk analysis", "trend report"],
      "counterExamples": ["CPU 높은 서버"]
    },
    "future_time_reference": {
      "source": "(내일|모레|다음\\s*주|다음\\s*달|[0-9]+\\s*시간\\s*후|[0-9]+\\s*일\\s*후|오전\\s*[0-9]|오후\\s*[0-9]|새벽\\s*[0-9])",
      "flags": "i",
      "description": "미래 특정 시점을 지정하는 표현 — 현재 데이터 기반 추세만 제공 가능함을 안내",
      "examples": ["내일 CPU 어떨까", "3시간 후 예측"],
      "counterExamples": ["지난 6시간 CPU 평균", "현재 서버 상태"]
    }
  }
}
