{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "headers": [
    {
      "source": "/api/ai/supervisor",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/api/version",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=600, stale-while-revalidate=1200"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/css/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/js/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "DISABLE_BACKGROUND_JOBS": "true",
    "DISABLE_CRON_JOBS": "true",
    "VERCEL_TIER": "pro"
  },
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=2048",
      "NEXT_DISABLE_DEVTOOLS": "1"
    }
  },
  "functions": {
    "src/app/api/ai/supervisor/route.ts": { "memory": 1024, "maxDuration": 60 },
    "src/app/api/ai/supervisor/stream/v2/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/ai/jobs/[id]/stream/route.ts": {
      "memory": 512,
      "maxDuration": 60
    },
    "src/app/api/ai/jobs/route.ts": { "memory": 512, "maxDuration": 30 },
    "src/app/api/ai/incident-report/route.ts": {
      "memory": 256,
      "maxDuration": 60
    },
    "src/app/api/ai/*/route.ts": { "memory": 256, "maxDuration": 30 },
    "src/app/api/*/route.ts": { "memory": 256, "maxDuration": 10 }
  }
}
