# Copy to config/renovate/.env and fill secrets before first run.

# GitLab SaaS
RENOVATE_PLATFORM=gitlab
RENOVATE_ENDPOINT=https://gitlab.com/api/v4/
RENOVATE_TOKEN=glpat_your_gitlab_bot_token

# Single-repo default. Override in shell if needed.
RENOVATE_REPOSITORY=skyasu2/openmanager-ai

# Optional but recommended to avoid GitHub changelog/rate-limit issues.
GITHUB_COM_TOKEN=

# Operational defaults
LOG_LEVEL=info
RENOVATE_REQUIRE_CONFIG=required
RENOVATE_ONBOARDING=false
RENOVATE_AUTODISCOVER=false
