model = "gpt-5.3-codex"
personality = "pragmatic"
model_reasoning_effort = "high"
sandbox = "danger-full-access"
ask_for_approval = "never"

[projects."__REPO_ROOT__"]
trust_level = "trusted"

[mcp_servers.supabase-db]
command = "bash"
args = ["__REPO_ROOT__/scripts/mcp/run-with-project-env.sh", "node", "__HOME__/.mcp-servers/supabase/node_modules/@supabase/mcp-server-supabase/dist/transports/stdio.js"]
startup_timeout_sec = 30
tool_timeout_sec = 120
required = false

[mcp_servers.supabase-db.env]
SUPABASE_ACCESS_TOKEN = "__OPENMANAGER_RUNTIME_ENV__"

[mcp_servers.supabase-db.tools.execute_sql]
approval_mode = "approve"

[mcp_servers.supabase-db.tools.apply_migration]
approval_mode = "approve"

[mcp_servers.diagram-converter]
command = "npx"
args = ["-y", "diagram-converter-mcp@0.2.6"]
startup_timeout_sec = 120
tool_timeout_sec = 180
required = false

[mcp_servers.diagram-converter.tools.mermaid_render]
approval_mode = "approve"

[mcp_servers.diagram-converter.tools.mermaid_batch_render]
approval_mode = "approve"

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp", "--output-dir", "tmp/playwright/mcp/screenshots"]
startup_timeout_sec = 60
tool_timeout_sec = 180
required = false

[mcp_servers.playwright.env]
DISPLAY = ":0"

[mcp_servers.playwright.tools.browser_tabs]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_navigate]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_run_code]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_click]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_evaluate]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_close]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_resize]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_type]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_press_key]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_fill_form]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_install]
approval_mode = "approve"

[mcp_servers.next-devtools]
command = "npx"
args = ["-y", "next-devtools-mcp@latest"]
startup_timeout_sec = 75
tool_timeout_sec = 120
required = false

[mcp_servers.next-devtools.tools.init]
approval_mode = "approve"

[mcp_servers.next-devtools.tools.nextjs_index]
approval_mode = "approve"

[mcp_servers.next-devtools.tools.nextjs_call]
approval_mode = "approve"

[mcp_servers.next-devtools.tools.browser_eval]
approval_mode = "approve"

[mcp_servers.next-devtools.tools.nextjs_docs]
approval_mode = "approve"

[mcp_servers.chrome-devtools]
command = "npx"
args = ["-y", "chrome-devtools-mcp@latest", "--isolated"]
startup_timeout_sec = 90
tool_timeout_sec = 180
required = false

[mcp_servers.chrome-devtools.env]
DISPLAY = ":0"

[mcp_servers.chrome-devtools.tools.take_memory_snapshot]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.lighthouse_audit]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.performance_start_trace]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.performance_stop_trace]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.new_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.take_snapshot]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.resize_page]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.take_screenshot]
approval_mode = "approve"

[mcp_servers.chrome-devtools.tools.click]
approval_mode = "approve"

[mcp_servers.github]
command = "bash"
args = ["__REPO_ROOT__/scripts/mcp/run-with-project-env.sh", "npx", "-y", "@modelcontextprotocol/server-github"]
startup_timeout_sec = 120
tool_timeout_sec = 120
required = false

[mcp_servers.github.env]
GITHUB_PERSONAL_ACCESS_TOKEN = "__OPENMANAGER_RUNTIME_ENV__"

[mcp_servers.github.tools.search_users]
approval_mode = "approve"

[mcp_servers.vercel]
command = "bash"
args = ["-lc", "set -a; source __REPO_ROOT__/.env.local >/dev/null 2>&1; set +a; npx -y vercel-mcp \"VERCEL_API_KEY=$VERCEL_API_KEY\""]
startup_timeout_sec = 180
tool_timeout_sec = 120
required = false

[mcp_servers.vercel.tools.getDeployments]
approval_mode = "approve"

[mcp_servers.vercel.tools.getDeployment]
approval_mode = "approve"

[mcp_servers.vercel.tools.getDeploymentEvents]
approval_mode = "approve"
