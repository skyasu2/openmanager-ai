# 🔐 보안 및 민감한 정보 방지

# API 키 및 토큰이 포함될 수 있는 파일들
**/secrets.*
**/api-keys.*
**/tokens.*
**/*secret*
**/*token*
**/*credential*

# But allow API route source files (not actual tokens)
!src/app/api/auth/revoke-github-token/
!src/app/api/dev/get-test-token/

# Allow pre-commit secret scanner scripts (they detect secrets, not contain them)
!scripts/env/*secret*.cjs
!scripts/env/*secret*.js

# 테스트 파일 (API 키가 포함될 수 있음)
test-gemini*.js
test-*-direct.js
test-*-lite.js

# CSRF 토큰 API는 예외 (보안 로직이므로 git에 포함)
!src/app/api/csrf-token/

# Token usage tracker는 예외 (실제 토큰이 아닌 사용량 추적 코드)
!cloud-run/ai-engine/src/lib/token-usage-tracker.ts
!src/app/api/csrf-token/**

