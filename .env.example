# OpenManager AI - Local Development Template
# 이 파일을 .env.local로 복사하고 실제 값으로 교체하세요
# ⚠️ 실제 프로덕션 키는 절대 Git에 커밋하지 마세요!

# =============================================================================
# 🔐 Auth Bypass (Development Only)
# =============================================================================
# true로 설정하면 로그인 없이 보호 경로 접근 가능 (프로덕션 금지)
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# =============================================================================
# 🗄️ Supabase Database (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_DB_PASSWORD=your-db-password-here

# =============================================================================
# 🤖 Google AI (Required for AI features)
# =============================================================================
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# =============================================================================
# 🔐 GitHub OAuth (Required for auth)
# =============================================================================
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
NEXTAUTH_SECRET=generate-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
# 게스트 로그인 차단 국가(ISO-3166 alpha-2, comma-separated). 기본값: CN
GUEST_LOGIN_BLOCKED_COUNTRIES=CN
# 게스트 전체 접근 허용(개발용). 프로덕션은 false/restricted 권장
NEXT_PUBLIC_GUEST_FULL_ACCESS=false
NEXT_PUBLIC_GUEST_MODE=restricted
# Vercel/원격 테스트에서 게스트 로그인 허용용 4자리 PIN
GUEST_LOGIN_PIN=1234

# =============================================================================
# ☁️ Cloud Run AI Engine (Optional)
# =============================================================================
CLOUD_RUN_AI_URL=https://ai-engine-xxx.asia-northeast1.run.app
CLOUD_RUN_API_SECRET=your-secure-api-secret-here

# =============================================================================
# ⚡ Vercel Tier Configuration
# =============================================================================
# Vercel 런타임/플랜 조정 타임아웃
# - 기본값/예산: VERCEL_TIER(또는 VERCEL_PLAN) + AI_MAX_FUNCTION_DURATION_SECONDS + AI_FUNCTION_TIMEOUT_RESERVE_MS
# - 참고(공식 Limits):
#   - Hobby(legacy): 기본 10초, 최대 60초
#   - Pro(legacy): 기본 15초, 최대 300초
#   - Fluid Compute: Hobby 기본 300초/최대 300초, Pro 기본 300초/최대 800초
#   - 본 프로젝트: maxDuration(라우트) + 운영 버퍼 적용으로 내부적으로 추가 가드
#   - 확인 기준일: 2026-02-20 (https://vercel.com/docs/limits/overview)
# 로컬 개발 기본값은 free. Production(vercel.json)은 pro.
# 단, 설계 목표는 Pro 전용 기능 의존이 아니라 Free-tier compatible profile 유지입니다.
# Free로 내려가더라도 핵심 경로는 유지되고, 악화는 대기시간/빌드 여유 수준에 머물러야 합니다.
VERCEL_TIER=free
# VERCEL_PLAN도 동일하게 pro/enterprise 판별에 사용됨
VERCEL_PLAN=free
# 라우트 타임아웃 상한(초): default는 tier별 보수값(Free 60 / Pro 300)
AI_MAX_FUNCTION_DURATION_SECONDS=60
# 요청 취소 버퍼(ms): 라우트 종료 안전 마진. 요청 본문 응답/로깅 여유용으로 사용
AI_FUNCTION_TIMEOUT_RESERVE_MS=1500

# =============================================================================
# 🖥️ GCP Settings (Optional)
# =============================================================================
VM_API_TOKEN=your-vm-api-token-here
GCP_PROJECT_ID=your-gcp-project-id

# =============================================================================
# 💾 Caching
# =============================================================================
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_MAX_SIZE=100
MEMORY_CACHE_TTL_SECONDS=900

# AI Job Stream 폴링 간격 (Redis 명령어 예산 최적화)
AI_JOB_STREAM_POLL_INTERVAL_MS=200
AI_JOB_STREAM_QUEUED_POLL_INTERVAL_MS=1000

# =============================================================================
# 📊 Monitoring
# =============================================================================
MONITORING_ENABLED=true
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true

# =============================================================================
# 🐛 Sentry (에러 모니터링, Optional)
# =============================================================================
# Production에서만 활성화. DSN 미설정 시 src/config/constants.ts의 fallback DSN 사용.
# SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
# SENTRY_AUTH_TOKEN=sntrys_xxx   # 소스맵 업로드용 (현재 비활성)

# =============================================================================
# 📊 Langfuse (LLM Observability, Cloud Run AI Engine 전용)
# =============================================================================
# Cloud Run 환경변수로 설정. 상세: cloud-run/ai-engine/.env.example
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_SAMPLE_RATE=0.1          # 샘플링 비율 (0.0~1.0, 기본 0.1=10%)
# LANGFUSE_TEST_MODE=false          # true 시 즉시 플러시, 100% 추적

# =============================================================================
# 📡 OpenTelemetry (기본 비활성화, 개발 디버깅용)
# =============================================================================
# 활성화 시 ConsoleExporter(stdout)만 동작, OTLP 백엔드 없음
# OTel 데이터는 빌드 타임(npm run data:otel)으로만 생성됨
# ENABLE_OPENTELEMETRY=false

# =============================================================================
# 🔧 Development
# =============================================================================
NODE_ENV=development
DEBUG_MODE=true
VERBOSE_LOGGING=false
